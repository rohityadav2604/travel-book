{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@memorybook/db": ["../../packages/db/src/index.ts"],
      "@memorybook/design": ["../../packages/design/src/index.ts"],
      "@memorybook/design/*": ["../../packages/design/src/*"],
      "@memorybook/shared": ["../../packages/shared/src/index.ts"],
      "@memorybook/shared/*": ["../../packages/shared/src/*"],
      "@memorybook/templates": ["../../packages/templates/src/index.ts"],
      "@memorybook/templates/*": ["../../packages/templates/src/*"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    "next.config.ts",
    "postcss.config.mjs",
    "tailwind.config.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
